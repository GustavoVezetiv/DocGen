# DocGen Configuration
# Environment: Development / Staging / Production

# ==========================================
# SERVER - FastAPI/Uvicorn
# ==========================================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ==========================================
# SECURITY - CORS e validação
# ==========================================
# Desenvolvimento: "*" (permite todas as origens)
# Produção: ["https://app.docgen.com", "https://docs.docgen.com"]
CORS_ORIGINS=*

# ==========================================
# API - Request/Response
# ==========================================
# Tamanho máximo do payload em bytes
# 1MB = 1048576
# 2MB = 2097152
# 5MB = 5242880
MAX_PAYLOAD_SIZE=1048576

# Timeout da requisição em segundos
REQUEST_TIMEOUT=120

# ==========================================
# WEASYPRINT - Motor de PDF
# ==========================================
# Enable/Disable WeasyPrint optimizations
WEASYPRINT_THREAD_POOL_SIZE=4

# ==========================================
# DATABASE - PostgreSQL (Fase 2)
# ==========================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=docgen
# DB_PASSWORD=secret
# DB_NAME=docgen_dev

# ==========================================
# AUTHENTICATION - JWT (Fase 2)
# ==========================================
# JWT_SECRET=your-super-secret-key-change-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_HOURS=24

# ==========================================
# MONITORING - APM (Fase 2+)
# ==========================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# DATADOG_API_KEY=xxx
# NEW_RELIC_LICENSE_KEY=xxx

# ==========================================
# ENVIRONMENT - Development/Production
# ==========================================
ENVIRONMENT=development
# ENVIRONMENT=production
DEBUG=True
# DEBUG=False
